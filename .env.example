# A.N.A Swahili Neural CLI Assistant Configuration Template
# ─────────────────────────────────────────────────────────────
# Nakili faili hili na ulipe jina la ".env", kisha weka funguo zako chini.

# 1. MTANDAO WA GROQ (Inapendekezwa - Kasi ya Juu Zaidi na BURE!)
# Pata ufunguo wa bure kabisa hapa: https://console.groq.com/
GROQ_API_KEY=weka_groq_api_key_yako_hapa
GROQ_MODEL=llama-3.3-70b-versatile

# 2. TEXT-TO-SPEECH (SAUTI) CONFIGURATION
# Weka "true" ili kuwasha sauti ya A.N.A kuongea majibu aloud kwa Kiswahili
SPEAK=false

# Chagua mtoa huduma wa sauti (TTS Provider):
# - 'google' (Inapendekezwa! Sauti nzuri sana ya mtandaoni, inasikika kama mwanamke halisi)
# - 'spd-say' (Sauti ya ndani ya Linux ya offline, female2)
# - 'elevenlabs' (Sauti ya kiwango cha juu cha binadamu ya ElevenLabs)
TTS_PROVIDER=google

# 3. ELEVENLABS CONFIGURATION (Ukichagua tts_provider=elevenlabs)
# Pata ufunguo wako kutoka elevenlabs.io
# ELEVENLABS_API_KEY=weka_elevenlabs_key_yako_hapa
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
